# Postgres connection string for the FastAPI backend and the scraper jobs.
DATABASE_URL=postgresql://coffee:coffee@localhost:5432/coffee_intel

# Comma-separated list of frontend origins allowed to call the API.
# Include your Vercel deploy URL(s) and any custom domain.
# Example: https://coffee-intel-map.vercel.app,https://coffee.example.com
CORS_ORIGINS=http://localhost:3000

# Set to "0" in long-running prod containers once the seed has been applied.
# Default "1" preserves the local-dev convenience of auto-seeding on startup.
SEED_ON_STARTUP=1

# Upstash Redis (REST) — used by acaphe_poller.py to publish live coffee
# quotes and by the frontend /api/live route to read them.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# UN Comtrade API key — only needed for the global fertilizer scraper's
# paid tier; falls back to the free (rate-limited) endpoint when blank.
COMTRADE_API_KEY=

# Telegram bot used by the GitHub Actions failure notifications
# (also consumed by the freshness-check workflows).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Compose-only — required so docker-compose db service refuses to start
# with a public default password. Mirror this in your prod environment.
POSTGRES_PASSWORD=coffee
